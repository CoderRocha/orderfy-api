{
  "info": {
    "name": "Orderfy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "orderId",
      "value": "v10089015vdb-01"
    }
  ],
  "item": [
    {
      "name": "Health Check da API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/",
        "description": "Verifica se a API está rodando."
      }
    },
    {
      "name": "Criar pedido",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/order",
        "description": "Cria um novo pedido com seus itens.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "options": {
            "raw": {
              "language": "json"
            }
          },
          "raw": "{\n  \"numeroPedido\": \"{{orderId}}\",\n  \"valorTotal\": 10000,\n  \"dataCriacao\": \"2023-07-19T12:24:11.5299601+00:00\",\n  \"items\": [\n    {\n      \"idItem\": \"2434\",\n      \"quantidadeItem\": 1,\n      \"valorItem\": 1000\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Buscar pedido por ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/order/{{orderId}}",
        "description": "Retorna os dados de um pedido específico pelo seu ID."
      }
    },
    {
      "name": "Listar todos os pedidos",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/order/list",
        "description": "Retorna todos os pedidos cadastrados com seus itens."
      }
    },
    {
      "name": "Atualizar pedido",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/order/{{orderId}}",
        "description": "Atualiza os dados de um pedido existente. Os itens são substituídos pelos novos enviados no body.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "options": {
            "raw": {
              "language": "json"
            }
          },
          "raw": "{\n  \"valorTotal\": 20000,\n  \"dataCriacao\": \"2023-07-20T09:00:00.000+00:00\",\n  \"items\": [\n    {\n      \"idItem\": \"2434\",\n      \"quantidadeItem\": 2,\n      \"valorItem\": 10000\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Deletar pedido",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/order/{{orderId}}",
        "description": "Remove um pedido e todos os seus itens."
      }
    }
  ]
}
